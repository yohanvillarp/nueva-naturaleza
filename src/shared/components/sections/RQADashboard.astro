---
// RQADashboard.astro
const { repo = "yohanvillarp/nueva-naturaleza" } = Astro.props;

const isTesting = false; 

let failedIssues = [];

if (isTesting) {
  failedIssues = [
    {
      number: 42,
      title: "Interfaz Intuitiva",
      body: "El sistema debe ser fácil de usar y rápido para todos los empleados de la institución.",
      html_url: "https://github.com/",
      user: { login: "analista_junior" },
      created_at: "2026-04-18T10:00:00Z",
      labels: [{ name: "RQA-FAILED", color: "ef4444" }, { name: "AMBIGUOUS", color: "f59e0b" }],
      rationale: "Falla de Verificación: Según el estándar, un requisito no puede contener adjetivos subjetivos ('fácil', 'rápido'). Carece de métricas comprobables (ISO/IEC 25000)."
    },
    {
      number: 55,
      title: "Registro de Usuarios",
      body: "Quiero registrarme con mi correo institucional sin poner muchos datos.",
      html_url: "https://github.com/",
      user: { login: "cliente_externo" },
      created_at: "2026-04-15T14:30:00Z",
      labels: [{ name: "RQA-FAILED", color: "ef4444" }, { name: "MISSING-ACTOR", color: "3b82f6" }],
      rationale: "Falla de Estructura: Ausencia del rol (Actor) en la sintaxis. La recolección debe ser un proceso analítico, no una simple transcripción del usuario final."
    },
    {
      number: 68,
      title: "Sincronización Offline",
      body: "La app tiene que guardar la info si no hay internet y subirla después sin fallar.",
      html_url: "https://github.com/",
      user: { login: "dev_backend" },
      created_at: "2026-04-20T08:15:00Z",
      labels: [{ name: "RQA-FAILED", color: "ef4444" }],
      rationale: "Falla de Integridad: Falta especificar límites de almacenamiento local (MB) y protocolos de reintento según IEEE 29148."
    }
  ];
} else {
  try {
    const TOKEN = import.meta.env.GITHUB_TOKEN;
    const response = await fetch(`https://api.github.com/repos/${repo}/issues?labels=RQA-FAILED&state=open`, {
        headers: TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}
    });
    const data = await response.json();
    
    failedIssues = Array.isArray(data) ? data.map((issue: any) => ({
      ...issue,
      rationale: issue.labels.some((l:any) => l.name === 'AMBIGUOUS') 
        ? "Falla de Verificación: El requisito contiene términos subjetivos y no es medible." 
        : "Infracción a las políticas de Elicitación y Análisis. Se requiere re-evaluación."
    })) : [];
  } catch (e) {
    console.error("Error fetching issues:", e);
    failedIssues = [];
  }
}

const hasErrors = failedIssues.length > 0;

const getDaysBlocked = (dateString: string) => {
  const diffTime = Math.abs(new Date().getTime() - new Date(dateString).getTime());
  return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
};

// Paleta dinámica Neo-brutalista
const cardThemes = [
  {
    bgHover: "hover:border-pink-500 hover:shadow-[12px_12px_0px_0px_#ec4899]",
    triangle: "bg-pink-500",
    badge: "text-pink-400 border-pink-500",
    badgeText: "text-pink-300",
    linkHover: "hover:bg-pink-500 hover:text-white"
  },
  {
    bgHover: "hover:border-cyan-400 hover:shadow-[12px_12px_0px_0px_#22d3ee]",
    triangle: "bg-cyan-400 text-black",
    badge: "text-cyan-300 border-cyan-400",
    badgeText: "text-cyan-200",
    linkHover: "hover:bg-cyan-400 hover:text-black"
  },
  {
    bgHover: "hover:border-amber-400 hover:shadow-[12px_12px_0px_0px_#fbbf24]",
    triangle: "bg-amber-400 text-black",
    badge: "text-amber-300 border-amber-400",
    badgeText: "text-amber-200",
    linkHover: "hover:bg-amber-400 hover:text-black"
  },
  {
    bgHover: "hover:border-purple-500 hover:shadow-[12px_12px_0px_0px_#a855f7]",
    triangle: "bg-purple-500",
    badge: "text-purple-400 border-purple-500",
    badgeText: "text-purple-300",
    linkHover: "hover:bg-purple-500 hover:text-white"
  }
];
---

<section id="rqa-dashboard" class="px-4 font-sans relative z-10 overflow-hidden min-h-screen">
  
  <div class="absolute top-10 left-10 w-20 h-20 bg-blue-500 rounded-full mix-blend-screen opacity-20 animate-[bounce_5s_infinite]"></div>
  <div class="absolute bottom-32 right-10 w-28 h-28 bg-pink-500 opacity-20 animate-[spin_10s_linear_infinite]" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%);"></div>
  <div class="absolute top-1/3 right-1/4 w-16 h-16 border-4 border-yellow-400 rotate-45 opacity-30 animate-[ping_3s_cubic-bezier(0,0,0.2,1)_infinite]"></div>
  <div class="absolute bottom-10 left-1/4 text-emerald-500/20 font-black text-6xl tracking-widest animate-[pulse_4s_ease-in-out_infinite]">〰〰〰</div>

  <div class="max-w-7xl mx-auto relative z-10 pb-20">
    
    <div class="bg-[#1a1f2e] border-4 border-indigo-500 rounded-2xl p-8 shadow-[12px_12px_0px_0px_#6366f1] relative hover:translate-x-1 hover:-translate-y-1 hover:shadow-[16px_16px_0px_0px_#6366f1] transition-all duration-300 mb-12">
      <div class="absolute -top-4 -right-4 w-12 h-12 bg-yellow-400 rounded-full border-4 border-[#0d1117] flex items-center justify-center font-black text-black z-20 shadow-lg">RQA</div>
      
      <div class="flex flex-col xl:flex-row justify-between items-start gap-8">
        
        <div class="flex-1">
          <h2 class="text-4xl md:text-5xl font-['Space_Grotesk'] font-black text-white uppercase tracking-tighter mb-6">
            Monitor de <span class="text-indigo-400">Calidad</span>
          </h2>
          
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <div class="inline-flex items-center gap-3 bg-black/40 px-5 py-2.5 border-2 border-indigo-500/50" style="border-radius: 4px 24px 4px 24px;">
              <span class="w-3 h-3 bg-green-400 rounded-full animate-ping"></span>
              <span class="text-sm text-indigo-200 font-mono font-bold tracking-widest">{repo}</span>
            </div>
            <a href="https://iso25000.com/index.php/normas-iso-25000" target="_blank" class="text-xs font-['Space_Grotesk'] text-indigo-300 underline hover:text-white transition-colors">
              Ref: Estándar SQuaRE (ISO/IEC 25000) ↗
            </a>
          </div>
        </div>

        <div class="xl:w-1/2 bg-[#0d1117] border-l-4 border-pink-500 p-6 rounded-r-2xl shadow-inner relative overflow-hidden group">
          <div class="absolute -right-4 -bottom-4 text-pink-500/10 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          
          <div class="relative z-10">
            <p class="text-gray-300 text-sm md:text-base font-medium italic leading-relaxed">
              "Una de las razones del fracaso de proyectos de software se debe al desconocimiento en el manejo del proceso de los requisitos en la fase temprana del proceso de desarrollo."
            </p>
            <div class="mt-4 flex items-center gap-3">
              <span class="w-6 h-0.5 bg-pink-500"></span>
              <span class="text-xs text-pink-400 font-['Space_Grotesk'] font-bold tracking-widest uppercase">
                Peláez, Toro, Arias y Rodríguez (2019)
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <div id="layout-container" class="grid grid-cols-1 lg:grid-cols-3 gap-8 transition-all duration-500">
      
      <div id="issues-area" class="lg:col-span-3 transition-all duration-500">
        {hasErrors ? (
          <div id="issues-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 transition-all duration-500">
            {failedIssues.map((issue: any, index: number) => {
              const theme = cardThemes[index % cardThemes.length];
              
              return (
              <div class={`group relative bg-[#1a1f2e] border-4 border-gray-700 rounded-none flex flex-col hover:-translate-y-2 transition-all duration-300 ${theme.bgHover}`}>
                
                <div class={`absolute -top-1 -left-1 w-16 h-16 z-10 flex items-start justify-start pt-2 pl-2 shadow-lg ${theme.triangle}`} style="clip-path: polygon(0 0, 100% 0, 0 100%);">
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 group-hover:scale-110 transition-transform ${theme.triangle.includes('text-black') ? 'text-black' : 'text-white'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>

                <div class="p-8 flex-1 mt-4">
                  <div class="flex justify-between items-center mb-6 pl-6">
                    <span class="bg-gray-800 text-white font-['Fira_Code'] font-black px-4 py-1 border-2 border-gray-600 rounded-full text-sm">
                      #{issue.number}
                    </span>
                    <span class={`bg-transparent font-['Space_Grotesk'] font-black px-3 py-1 text-xs uppercase tracking-widest border-b-4 ${theme.badge}`}>
                      Bloqueo: {getDaysBlocked(issue.created_at)}D
                    </span>
                  </div>

                  <h3 class="text-2xl font-['Space_Grotesk'] font-black text-white mb-4 leading-tight">{issue.title}</h3>
                  
                  <div class="bg-black border-2 border-gray-600 p-5 mb-6 relative shadow-inner" style="border-radius: 16px 0px 16px 0px;">
                    <span class={`absolute -top-3 left-4 bg-gray-800 text-[10px] font-['Space_Grotesk'] font-black px-3 py-1 uppercase tracking-widest border border-gray-600 rounded-full ${theme.badgeText}`}>
                      Input Original
                    </span>
                    <p class="text-gray-300 font-['Fira_Code'] text-sm mt-2">"{issue.body}"</p>
                  </div>

                  <div class="bg-gray-800/50 border-l-8 border-gray-600 p-4">
                    <p class="text-gray-400 font-['Space_Grotesk'] font-black text-xs uppercase tracking-widest mb-1">Diagnóstico (SQA):</p>
                    <p class="text-sm text-gray-200 font-medium">{issue.rationale}</p>
                  </div>
                </div>

                <div class="bg-gray-800 border-t-4 border-gray-700 p-0 overflow-hidden">
                  <a 
                    href={issue.html_url} 
                    target="_blank" 
                    class={`block w-full text-center bg-transparent text-white font-['Space_Grotesk'] font-black uppercase tracking-widest text-sm py-5 transition-all duration-300 transform group-hover:scale-105 ${theme.linkHover}`}
                  >
                    Refactorizar Requisito
                  </a>
                </div>
              </div>
            )})}
          </div>
        ) : (
          <div class="bg-[#1a1f2e] border-4 border-emerald-500 p-16 text-center flex flex-col items-center justify-center shadow-[12px_12px_0px_0px_#10b981] hover:translate-x-1 hover:-translate-y-1 transition-transform" style="border-radius: 40px 8px 40px 8px;">
            <div class="w-28 h-28 bg-emerald-500 rounded-full flex items-center justify-center mb-8 border-8 border-[#0d1117] shadow-xl relative z-10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-[#0d1117] animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h3 class="text-4xl font-['Space_Grotesk'] font-black text-white mb-4 uppercase tracking-tighter">Tubería Despejada</h3>
            <p class="text-emerald-200 text-lg max-w-xl mx-auto font-medium bg-black/30 p-4 border-2 border-emerald-500/30 rounded-xl shadow-inner">
              Validación exitosa. Todos los requisitos estructurales cumplen al 100% con los criterios de calidad.
            </p>
          </div>
        )}
      </div>

      <aside id="rules-sidebar" class="hidden lg:col-span-1 transition-all duration-500 opacity-0 transform translate-x-8">
        <div class="sticky top-32 bg-[#0d1117] border-4 border-yellow-400 rounded-2xl p-6 shadow-[12px_12px_0px_0px_#facc15] flex flex-col justify-center">
          
          <div class="flex justify-between items-start border-b-2 border-yellow-400/20 pb-4 mb-6">
            <h3 class="text-yellow-400 font-['Space_Grotesk'] font-black uppercase tracking-widest flex items-center gap-3 text-lg leading-tight">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
              Directrices SQA
            </h3>
            <button id="btn-close-rules" class="text-gray-400 hover:text-white bg-gray-800 p-1 border-2 border-gray-600 rounded-md transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          </div>
          
          <ul class="space-y-4">
            <li class="flex items-start gap-4 bg-[#1a1f2e] p-4 border-2 border-yellow-400/30 rounded-xl">
              <div class="bg-yellow-400 p-2 rounded-lg text-black shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4"></path></svg>
              </div>
              <div>
                <strong class="text-yellow-400 font-['Space_Grotesk'] text-[11px] tracking-widest uppercase block mb-1">Estructura SRS</strong>
                <p class="text-gray-300 text-xs font-medium">Requisito debe definir el actor: <br/> <code class="bg-black text-yellow-200 px-1 py-0.5 mt-1 block">Como [Rol], quiero...</code></p>
              </div>
            </li>

            <li class="flex items-start gap-4 bg-[#1a1f2e] p-4 border-2 border-pink-500/30 rounded-xl">
              <div class="bg-pink-500 p-2 rounded-lg text-white shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <div>
                <strong class="text-pink-400 font-['Space_Grotesk'] text-[11px] tracking-widest uppercase block mb-1">Cero Ambigüedad</strong>
                <p class="text-gray-300 text-xs font-medium">Evitar "rápido" o "fácil". Exigir magnitudes físicas (s, MB, px).</p>
              </div>
            </li>

            <li class="flex items-start gap-4 bg-[#1a1f2e] p-4 border-2 border-emerald-500/30 rounded-xl">
              <div class="bg-emerald-500 p-2 rounded-lg text-black shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04"></path></svg>
              </div>
              <div>
                <strong class="text-emerald-400 font-['Space_Grotesk'] text-[11px] tracking-widest uppercase block mb-1">Verificabilidad</strong>
                <p class="text-gray-300 text-xs font-medium">Todo criterio debe poder validarse de forma binaria (Pasa/Falla).</p>
              </div>
            </li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</section>

<button 
  id="btn-open-rules" 
  class="fixed bottom-8 right-8 z-[110] bg-yellow-400 text-[#0d1117] border-4 border-[#0d1117] shadow-[6px_6px_0_0_#0d1117] p-4 rounded-full hover:-translate-y-2 hover:shadow-[10px_10px_0_0_#0d1117] transition-all duration-300 flex items-center justify-center group"
  aria-label="Abrir Cheat Sheet ISO 25000"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
  </svg>
</button>

<script>
  const btnOpen = document.getElementById('btn-open-rules');
  const btnClose = document.getElementById('btn-close-rules');
  const rulesSidebar = document.getElementById('rules-sidebar');
  const issuesArea = document.getElementById('issues-area');
  const issuesGrid = document.getElementById('issues-grid');

  function openRules() {
    rulesSidebar.classList.remove('hidden');
    setTimeout(() => {
      rulesSidebar.classList.remove('opacity-0', 'translate-x-8');
    }, 50);

    btnOpen.classList.add('translate-y-32', 'opacity-0');
    btnOpen.style.pointerEvents = 'none';

    issuesArea.classList.replace('lg:col-span-3', 'lg:col-span-2');

    if(issuesGrid) {
      issuesGrid.classList.replace('md:grid-cols-2', 'md:grid-cols-1');
      issuesGrid.classList.replace('lg:grid-cols-2', 'lg:grid-cols-1');
    }
  }

  function closeRules() {
    rulesSidebar.classList.add('opacity-0', 'translate-x-8');
    
    setTimeout(() => {
      rulesSidebar.classList.add('hidden');
      
      btnOpen.classList.remove('translate-y-32', 'opacity-0');
      btnOpen.style.pointerEvents = 'auto';

      issuesArea.classList.replace('lg:col-span-2', 'lg:col-span-3');

      if(issuesGrid) {
        issuesGrid.classList.replace('md:grid-cols-1', 'md:grid-cols-2');
        issuesGrid.classList.replace('lg:grid-cols-1', 'lg:grid-cols-2');
      }
    }, 300);
  }

  btnOpen?.addEventListener('click', openRules);
  btnClose?.addEventListener('click', closeRules);
</script>