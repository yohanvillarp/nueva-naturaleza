---
// RQADashboard.astro
const { repo = "yohanvillarp/nueva-naturaleza" } = Astro.props;

// Cambia a false en producción
const isTesting = false; 

let failedIssues = [];

if (isTesting) {
  failedIssues = [
    {
      number: 42,
      title: "Interfaz Intuitiva",
      body: "El sistema debe ser fácil de usar y rápido para todos los empleados de la institución.",
      html_url: "https://github.com/",
      user: { login: "analista_junior" },
      created_at: "2026-04-18T10:00:00Z",
      labels: [{ name: "RQA-FAILED", color: "ef4444" }, { name: "AMBIGUOUS", color: "f59e0b" }],
      rationale: "Falla de Verificación: Según el estándar, un requisito no puede contener adjetivos subjetivos ('fácil', 'rápido'). Carece de métricas comprobables (ISO/IEC 25000)."
    },
    {
      number: 55,
      title: "Registro de Usuarios",
      body: "Quiero registrarme con mi correo institucional sin poner muchos datos.",
      html_url: "https://github.com/",
      user: { login: "cliente_externo" },
      created_at: "2026-04-15T14:30:00Z",
      labels: [{ name: "RQA-FAILED", color: "ef4444" }, { name: "MISSING-ACTOR", color: "3b82f6" }],
      rationale: "Falla de Estructura: Ausencia del rol (Actor) en la sintaxis. La recolección debe ser un proceso analítico, no una simple transcripción del usuario final."
    }
  ];
} else {
  try {
    const TOKEN = import.meta.env.GITHUB_TOKEN;
    const response = await fetch(`https://api.github.com/repos/${repo}/issues?labels=RQA-FAILED&state=open`, {
        headers: TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}
    });
    const data = await response.json();
    
    failedIssues = Array.isArray(data) ? data.map((issue: any) => ({
      ...issue,
      rationale: issue.labels.some((l:any) => l.name === 'AMBIGUOUS') 
        ? "Falla de Verificación: El requisito contiene términos subjetivos y no es medible." 
        : "Infracción a las políticas de Elicitación y Análisis. Se requiere re-evaluación."
    })) : [];
  } catch (e) {
    console.error("Error fetching issues:", e);
    failedIssues = [];
  }
}

const hasErrors = failedIssues.length > 0;

const getDaysBlocked = (dateString: string) => {
  const diffTime = Math.abs(new Date().getTime() - new Date(dateString).getTime());
  return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
};
---

<section id="rqa-dashboard" class="py-16 px-4 font-sans relative z-10">
  <div class="max-w-6xl mx-auto">
    
    <div class="flex flex-col lg:flex-row gap-6 mb-12">
      <div class="flex-1 bg-white/5 border-2 border-white/20 rounded-3xl p-8 backdrop-blur-sm shadow-[8px_8px_0px_0px_rgba(255,255,255,0.05)]">
        <h2 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-2">
          Monitor <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">RQA</span>
        </h2>
        <p class="text-gray-400 font-medium text-lg">Inspección de Calidad ISO/IEC 25000</p>
        <div class="mt-6 inline-flex items-center gap-2 bg-black/40 px-4 py-2 rounded-full border border-white/10">
          <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          <span class="text-xs text-gray-300 font-mono">{repo}</span>
        </div>
      </div>

      <div class={`w-full lg:w-72 flex flex-col justify-center items-center rounded-3xl p-8 border-2 border-white/20 shadow-[8px_8px_0px_0px_rgba(255,255,255,0.05)] backdrop-blur-sm ${hasErrors ? 'bg-red-500/10' : 'bg-emerald-500/10'}`}>
        <span class={`text-6xl font-black mb-2 ${hasErrors ? 'text-red-400' : 'text-emerald-400'}`}>
          {failedIssues.length}
        </span>
        <span class="text-sm font-bold uppercase tracking-widest text-gray-300 text-center">
          {hasErrors ? 'Bloqueos de Calidad' : 'Zero Defectos'}
        </span>
      </div>
    </div>

    {hasErrors ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {failedIssues.map((issue: any) => (
          <div class="group relative bg-[#1a1f2e] border-2 border-gray-700 rounded-2xl flex flex-col hover:-translate-y-2 hover:border-red-500 hover:shadow-[8px_8px_0px_0px_#ef4444] transition-all duration-300">
            
            <div class="absolute -top-5 -left-5 w-12 h-12 bg-red-500 rounded-full flex items-center justify-center border-4 border-[#0d1117] shadow-lg z-10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>

            <div class="p-8 flex-1">
              <div class="flex justify-between items-start mb-6 pl-4">
                <span class="inline-block bg-gray-800 text-gray-300 font-mono font-bold px-3 py-1.5 rounded-lg text-sm border border-gray-700">
                  #{issue.number}
                </span>
                <span class="inline-block bg-orange-500/20 text-orange-400 font-bold px-3 py-1.5 rounded-lg text-xs uppercase tracking-wider border border-orange-500/30">
                  ⏳ {getDaysBlocked(issue.created_at)} días
                </span>
              </div>

              <h3 class="text-2xl font-bold text-white mb-4 leading-tight">{issue.title}</h3>
              
              <div class="bg-black/30 border-2 border-dashed border-gray-600 rounded-xl p-5 mb-6 relative">
                <span class="absolute -top-3 left-4 bg-gray-800 text-gray-300 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-widest">
                  Texto Analizado
                </span>
                <p class="text-gray-300 italic">"{issue.body}"</p>
              </div>

              <div class="bg-blue-500/10 border-l-4 border-blue-500 p-4 rounded-r-xl">
                <p class="text-blue-400 font-bold text-xs uppercase tracking-widest mb-1">Diagnóstico ISO:</p>
                <p class="text-sm text-gray-200 font-medium">{issue.rationale}</p>
              </div>
            </div>

            <div class="border-t-2 border-gray-700 bg-gray-800/50 p-4 rounded-b-2xl">
              <a 
                href={issue.html_url} 
                target="_blank" 
                class="block w-full text-center bg-white text-black hover:bg-gray-200 font-black uppercase tracking-wider text-sm py-4 rounded-xl transition-colors"
              >
                Ejecutar Corrección →
              </a>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="bg-emerald-500/5 border-2 border-emerald-500/20 rounded-3xl p-16 text-center flex flex-col items-center justify-center shadow-[8px_8px_0px_0px_rgba(16,185,129,0.1)]">
        <div class="w-32 h-32 bg-emerald-500/20 rounded-full flex items-center justify-center mb-8 border-4 border-emerald-500/30 relative">
            <div class="absolute inset-0 bg-emerald-500/20 rounded-full animate-ping"></div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        <h3 class="text-4xl font-black text-white mb-4 uppercase tracking-tight">Tubería Despejada</h3>
        <p class="text-gray-400 text-lg max-w-xl mx-auto font-medium">
          Los requisitos estructurales cumplen al 100% con los criterios de aceptación. El código puede ser desplegado de manera segura.
        </p>
      </div>
    )}
  </div>
</section>