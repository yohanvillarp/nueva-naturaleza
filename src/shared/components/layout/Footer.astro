---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary pt-24 pb-12 border-t border-white/5 text-white">
  <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20">
    
    <div class="flex flex-col gap-6">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center shadow-lg">
        <img src="/nn.webp" alt="Logo" class="w-full h-full object-contain rounded-2xl" />
      </div>
      <p class="max-w-xs text-sm opacity-60 leading-relaxed font-medium">
        Reconectando la tecnología con el corazón de la Amazonía. Un futuro sostenible es un futuro integrado.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-8">
      <div class="flex flex-col gap-6">
        <h4 class="text-xs font-black uppercase tracking-[0.2em] text-accent">Proyecto</h4>
        <nav class="flex flex-col gap-3">
          <a href="#inicio" class="text-sm opacity-60 hover:text-accent hover:opacity-100 transition-all hover:translate-x-1">Inicio</a>
          <a href="#objetivo" class="text-sm opacity-60 hover:text-accent hover:opacity-100 transition-all hover:translate-x-1">Objetivos</a>
          <a href="#arquitectura" class="text-sm opacity-60 hover:text-accent hover:opacity-100 transition-all hover:translate-x-1">Arquitectura</a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
        <h4 class="text-xs font-black uppercase tracking-[0.2em] text-accent">Legal</h4>
        <nav class="flex flex-col gap-3">
          <a href="#" class="text-sm opacity-60 hover:text-accent hover:opacity-100 transition-all">Privacidad</a>
          <a href="#" class="text-sm opacity-60 hover:text-accent hover:opacity-100 transition-all">Términos</a>
        </nav>
      </div>

      <div class="flex flex-col gap-6 col-span-2 md:col-span-1">
        <h4 class="text-xs font-black uppercase tracking-[0.2em] text-accent">Contacto</h4>
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3 text-sm opacity-70 group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:scale-110 transition-transform"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span class="break-all">hola@nuevanaturaleza.com</span>
          </div>
          <div class="flex items-center gap-3 text-sm opacity-70 group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent group-hover:scale-110 transition-transform"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.31-2.31a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>+51 901456336</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-6 pt-12 border-t border-white/5 flex flex-col md:row justify-between items-center gap-6 opacity-40 text-[10px] font-bold uppercase tracking-widest">
    <p>&copy; {currentYear} Nueva Naturaleza. Todos los derechos reservados.</p>
    <div class="flex gap-8">
      <a href="#" class="hover:text-accent transition-colors">Facebook</a>
      <a href="#" class="hover:text-accent transition-colors">Instagram</a>
      <a href="#" class="hover:text-accent transition-colors">LinkedIn</a>
    </div>
  </div>
</footer>
